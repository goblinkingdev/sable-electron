{
  "name": "sable-desktop",
  "version": "1.0.3-1.16.0",
  "description": "Unofficial Electron desktop wrapper for Sable Matrix client",
  "main": "dist-electron/main.js",
  "author": {
    "name": "GoblinKing",
    "email": "goblinking_f@proton.me"
  },
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "npm run build:electron && electron .",
    "build:sable": "cd sable && pnpm install --frozen-lockfile && pnpm build",
    "build:electron": "tsc -p tsconfig.json",
    "build": "npm run build:sable && npm run build:electron",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:ci": "electron-builder"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.0.0"
  }
}
